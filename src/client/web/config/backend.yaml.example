# AgentCrafter Web Backend Configuration Example
# Copy this file to backend.yaml and modify as needed

# Project settings
project:
  name: AgentCrafter
  version: 1.0.0
  root: ${PROJECT_ROOT}  # Optional, auto-detected if not set

# Database configuration
database:
  # Option 1: Direct database URL
  # url: sqlite:///./agentcrafter_users.db
  # url: postgresql://username:password@localhost/agentcrafter
  # url: mysql://username:password@localhost/agentcrafter

  # Option 2: Database file path (SQLite only)
  # Relative path: relative to project root
  path: dbfiles/agentcrafter.db
  # Absolute path example:
  # path: /path/to/your/database/agentcrafter_users.db

# Server configuration
server:
  host: 0.0.0.0
  port: 8000
  reload: true  # Enable hot reload in development

# Security configuration
security:
  # IMPORTANT: Change this in production!
  secret_key: your-secret-key-here-change-in-production
  algorithm: HS256
  access_token_expire_minutes: 30

# Logging configuration
logging:
  level: INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# LLM API keys (optional, can also be set via environment variables)
# llm:
#   openai_api_key: ${OPENAI_API_KEY}
#   anthropic_api_key: ${ANTHROPIC_API_KEY}
