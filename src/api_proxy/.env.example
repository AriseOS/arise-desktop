# API Proxy Environment Variables
# Copy to .env: cp .env.example .env

# ===== Required: Domain & SSL =====
DOMAIN=api.example.com
ACME_EMAIL=admin@example.com

# ===== Required: Security Keys =====
# Generate: python -m src.api_proxy.setup generate-keys
JWT_SECRET=
ENCRYPTION_KEY=
ADMIN_PASSWORD=

# ===== Required: LLM API =====
ANTHROPIC_API_KEY=

# ===== Optional: Database =====
DB_PASSWORD=ami-postgres-strong-password

# ===== Optional: Admin Account =====
# ADMIN_USERNAME=admin
# ADMIN_EMAIL=admin@ami.com

# All other settings use defaults from config/api-proxy.yaml
