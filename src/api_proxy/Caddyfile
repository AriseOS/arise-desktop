# Caddy Configuration for API Proxy
# Auto HTTPS with Let's Encrypt

# Main API endpoint
{$DOMAIN:api.example.com} {
    # Enable access logs
    log {
        output file /data/logs/access.log {
            roll_size 100mb
            roll_keep 10
            roll_keep_for 720h
        }
        format json
    }

    # Reverse proxy to API Proxy service
    reverse_proxy api-proxy:8080 {
        # Health check
        health_uri /health
        health_interval 10s
        health_timeout 5s
        health_status 200

        # Headers
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Security headers
    header {
        # HSTS (force HTTPS for 1 year)
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

        # Prevent MIME type sniffing
        X-Content-Type-Options "nosniff"

        # Prevent clickjacking
        X-Frame-Options "DENY"

        # XSS protection
        X-XSS-Protection "1; mode=block"

        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"

        # Content Security Policy (adjust as needed)
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"

        # Hide server info
        -Server
    }

    # Enable compression
    encode gzip zstd

    # Custom error pages (optional)
    handle_errors {
        @502-504 expression {http.error.status_code} in [502, 503, 504]
        respond @502-504 "Service temporarily unavailable. Please try again later." 503
    }
}

# Development: localhost without HTTPS (optional)
# Uncomment for local testing
# localhost:8080 {
#     reverse_proxy api-proxy:8080
# }
