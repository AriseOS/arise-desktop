# Ami Cloud Backend Environment Variables
# Copy this file to .env and fill in actual values:
#   cp .env.example .env

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-here

# Sub2API Admin (per-user token management)
SUB2API_ADMIN_API_KEY=your-sub2api-admin-key

# Embedding Service (server-side, not per-user)
# Used for text vectorization (SiliconFlow, OpenAI, or any OpenAI-compatible API)
EMBEDDING_API_KEY=sk-your-embedding-api-key

# Rerank Service (server-side, not per-user, optional)
# Used for document re-ranking (SiliconFlow, Cohere, or any compatible API)
RERANK_API_KEY=sk-your-rerank-api-key
