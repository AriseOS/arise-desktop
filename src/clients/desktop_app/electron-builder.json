{
  "appId": "com.arise.ami",
  "productName": "Ami",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "electron/**/*"
  ],
  "extraResources": [
    {
      "from": "resources/",
      "to": "Resources/",
      "filter": ["**/*"]
    }
  ],
  "mac": {
    "category": "public.app-category.productivity",
    "icon": "src-tauri/icons/icon.icns",
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64"]
      },
      {
        "target": "dir",
        "arch": ["arm64"]
      }
    ],
    "hardenedRuntime": true,
    "gatekeeperAssess": false
  },
  "dmg": {
    "contents": [
      { "x": 130, "y": 220 },
      { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
    ]
  },
  "win": {
    "icon": "src-tauri/icons/icon.ico",
    "target": [
      {
        "target": "dir",
        "arch": ["x64"]
      }
    ]
  }
}
