# =============================================================================
# Ami Production Environment Configuration
# =============================================================================
# Copy to .env and fill in all required values:
#   cp .env.example .env && nano .env
# =============================================================================

# --- Domain ---
# Your production domain (used by Caddy for auto HTTPS)
DOMAIN=api.ariseos.com
# Bind address (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
BIND_HOST=0.0.0.0

# --- Cloud Backend (REQUIRED) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change_this_to_a_secure_random_string
# Embedding service API key (e.g., Silicon Flow, OpenAI, etc.)
EMBEDDING_API_KEY=your-embedding-api-key
# Optional: Rerank service API key
RERANK_API_KEY=

# --- Sub2API Admin Key (REQUIRED) ---
# This is the x-api-key for sub2api's admin API
# Will be shown in sub2api logs on first run, or set ADMIN_PASSWORD below
SUB2API_ADMIN_API_KEY=your-sub2api-admin-api-key

# --- SurrealDB (REQUIRED) ---
SURREALDB_USER=root
SURREALDB_PASSWORD=change_this_secure_password

# --- PostgreSQL (REQUIRED, used by sub2api) ---
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_DB=sub2api

# --- Redis ---
REDIS_PASSWORD=
REDIS_DB=0

# --- Sub2API ---
SERVER_MODE=release
RUN_MODE=standard
ADMIN_EMAIL=admin@ariseos.com
ADMIN_PASSWORD=
# Generate with: openssl rand -hex 32
SUB2API_JWT_SECRET=change_this_to_a_secure_random_string
SUB2API_JWT_EXPIRE_HOUR=24
TOTP_ENCRYPTION_KEY=

# --- Timezone ---
TZ=Asia/Shanghai
