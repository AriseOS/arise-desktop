# =============================================================================
# Ami Cloud Backend - Environment Configuration
# =============================================================================
# Copy to .env and fill in all required values:
#   cp .env.example .env && nano .env
#
# Also edit cloud-backend.yaml to set llm.proxy_url to your sub2api address.
# =============================================================================

# --- Cloud Backend (REQUIRED) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# --- SurrealDB (REQUIRED) ---
SURREALDB_PASSWORD=
# SURREALDB_USER=root  # default: root

# --- Sub2API (REQUIRED) ---
# Admin API key from sub2api (x-api-key header for admin operations)
SUB2API_ADMIN_API_KEY=

# --- Embedding Service (REQUIRED) ---
# API key for embedding provider (e.g., SiliconFlow, OpenAI)
EMBEDDING_API_KEY=

# --- Rerank Service (OPTIONAL) ---
# Leave empty to disable rerank
RERANK_API_KEY=

# --- Network (OPTIONAL) ---
# BIND_HOST=127.0.0.1  # default: 127.0.0.1 (localhost only, use caddy to reverse proxy)

# --- Timezone (OPTIONAL) ---
# TZ=Asia/Shanghai
