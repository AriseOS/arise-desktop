# AgentCrafter Backend Configuration
# 复制此文件为 .env 并根据需要修改配置

# ===================
# 项目配置
# ===================

# 项目根目录（可选，默认自动检测）
# PROJECT_ROOT=/path/to/agentcrafter

# ===================
# 数据库配置
# ===================

# 方式1：直接指定完整的数据库URL
# DATABASE_URL=sqlite:///./agentcrafter_users.db
# DATABASE_URL=postgresql://username:password@localhost/agentcrafter
# DATABASE_URL=mysql://username:password@localhost/agentcrafter

# 方式2：指定数据库文件路径（仅适用于SQLite）
# 相对路径：相对于项目根目录
DATABASE_PATH=dbfiles/agentcrafter.db
# 绝对路径：
# DATABASE_PATH=/path/to/your/database/agentcrafter_users.db

# ===================
# 服务器配置
# ===================

# 后端服务器主机地址
BACKEND_HOST=0.0.0.0

# 后端服务器端口
BACKEND_PORT=8000

# 开发模式下是否启用热重载
BACKEND_RELOAD=true

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ===================
# 安全配置
# ===================

# JWT密钥 - 生产环境中请更改为强密钥
SECRET_KEY=your-secret-key-here-change-in-production

# ===================
# 其他配置
# ===================

# OpenAI API密钥（如果需要）
# OPENAI_API_KEY=your_openai_key_here

# Anthropic API密钥（如果需要）
# ANTHROPIC_API_KEY=your_anthropic_key_here
