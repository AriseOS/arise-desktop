# 数据库配置
DATABASE_URL=postgresql://postgres:password@localhost:5432/agentcrafter
REDIS_URL=redis://localhost:6379/0

# API 配置
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Claude API 配置 (用于 Agent 构建)
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_MODEL=claude-3-sonnet-20240229

# 工具配置
ANDROID_EMULATOR_HOST=localhost
ANDROID_EMULATOR_PORT=5554
BROWSER_HEADLESS=true

# 容器配置
DOCKER_HOST=unix:///var/run/docker.sock
AGENT_CONTAINER_NETWORK=agentcrafter_default

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json

# 监控配置
ENABLE_METRICS=true
METRICS_PORT=9090

# 安全配置
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# 文件存储
AGENTS_DIR=./agents
LOGS_DIR=./logs
CONFIG_DIR=./config